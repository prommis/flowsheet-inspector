{
    "name": "flowsheet-inspector",
    "publisher": "idaes-team",
    "displayName": "Flowsheet-inspector",
    "description": "",
    "version": "0.0.2",
    "engines": {
        "vscode": "^1.106.0"
    },
    "categories": [
        "Other"
    ],
    "icon": "resources/prommis_icon.png",
    "activationEvents": [
        "onView:idaes.treeView",
        "onView:idaes.webView"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "flowsheet-inspector.start",
                "title": "IDAES Start"
            },
            {
                "command": "flowsheet-inspector.openWebView",
                "title": "Open IDAES Flowsheet Inspector",
                "icon": "$(open-preview)"
            },
            {
                "command": "flowsheet-inspector.reloadWebview",
                "title": "IDAES: Reload Webview (Dev)",
                "icon": "$(refresh)"
            }
        ],
        "keybindings": [
            {
                "command": "flowsheet-inspector.reloadWebview",
                "key": "cmd+shift+r",
                "mac": "cmd+shift+r",
                "win": "ctrl+shift+r",
                "linux": "ctrl+shift+r",
                "when": "editorTextFocus"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "flowsheet-inspector.openWebView",
                    "when": "!editorReadonly && resourceLangId == python",
                    "group": "navigation"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "idaes-activity-bar",
                    "title": "IDAES Control",
                    "icon": "resources/prommis_icon.svg"
                }
            ]
        },
        "views": {
            "idaes-activity-bar": [
                {
                    "id": "idaes.treeView",
                    "name": "Run Control",
                    "icon": "resources/prommis_icon.svg",
                    "type": "webview"
                }
            ]
        }
    },
    "scripts": {
        "package": "npm run compile && cd ../webview_ui && npm run build && cd ../extension && vsce package",
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch:build": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.106.1",
        "@vscode/test-cli": "^0.0.11",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.39.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.48.1"
    }
}
